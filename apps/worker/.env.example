# apps/worker environment — placeholders only, never real values.
# Full registry with "required when" triggers: docs/deployment/DEPLOYMENT.md §6.

# Keep the stub process alive on Railway (without it the stub exits cleanly
# and the on-failure restart policy never restarts it).
WORKER_HEARTBEAT=1

# Neon PostgreSQL (outbox polling, first Neon-backed slice)
DATABASE_URL=postgresql://app_user:<password>@ep-example-123-pooler.us-east-2.aws.neon.tech/aflo?sslmode=require
DIRECT_DATABASE_URL=postgresql://app_owner:<password>@ep-example-123.us-east-2.aws.neon.tech/aflo?sslmode=require

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Monitoring
SENTRY_DSN=https://<key>@o000000.ingest.sentry.io/0000000

# AI provider behind the internal interface — "mock" is supported forever
AI_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# App
APP_BASE_URL=http://localhost:3000
