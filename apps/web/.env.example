# apps/web environment — placeholders only, never real values.
# The current visual slice needs NONE of these: it runs on in-memory mock
# repositories with synthetic data and makes no external calls.
# Full registry with "required when" triggers: docs/deployment/DEPLOYMENT.md §6.

# Neon PostgreSQL (first Neon-backed slice)
DATABASE_URL=postgresql://app_user:<password>@ep-example-123-pooler.us-east-2.aws.neon.tech/aflo?sslmode=require

# Auth — Clerk (recommended, ADR-0006) …
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
# … or Auth.js, if chosen instead
AUTH_SECRET=<random-32-byte-base64>
AUTH_URL=https://app.example.com

# Document storage (Vercel Blob or S3-compatible)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Analytics & monitoring
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://<key>@o000000.ingest.sentry.io/0000000

# App
APP_BASE_URL=http://localhost:3000
