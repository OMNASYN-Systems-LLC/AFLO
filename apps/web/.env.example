# apps/web environment — placeholders only, never real values.
# Full registry with "required when" triggers: docs/deployment/DEPLOYMENT.md §6.

# Runtime contract (ADR-0017 + ADR-0048). EVERY deployment must resolve the
# runtime explicitly — there is no implicit default:
#   APP_ENV=demo        → the demo/synthetic prototype (EXPLICIT opt-in; the
#                          only way demo identities/synthetic data are served).
#                          Local `pnpm dev` gets this from the committed
#                          apps/web/.env.development; Vercel prototype
#                          deployments must set it in the dashboard.
#   APP_ENV=preview|production + AUTH_MODE=clerk + REPOSITORY_MODE=postgres
#                       → the real runtime (production additionally requires
#                          the full ADR-0017 integration set below).
# Anything ambiguous (no opt-in, partial mode selection) refuses to boot.
APP_ENV=demo
# AUTH_MODE=clerk
# REPOSITORY_MODE=postgres
# SEED_MODE=off
# DATABASE_BRANCH=main

# Neon PostgreSQL (first Neon-backed slice)
DATABASE_URL=postgresql://app_user:<password>@ep-example-123-pooler.us-east-2.aws.neon.tech/aflo?sslmode=require

# Auth — Clerk (recommended, ADR-0006) …
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
# … or Auth.js, if chosen instead
AUTH_SECRET=<random-32-byte-base64>
AUTH_URL=https://app.example.com

# Document storage (Vercel Blob or S3-compatible)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Analytics & monitoring
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://<key>@o000000.ingest.sentry.io/0000000

# App
APP_BASE_URL=http://localhost:3000
