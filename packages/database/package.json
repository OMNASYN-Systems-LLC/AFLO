{
  "name": "@aflo/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Neon PostgreSQL schema (Drizzle ORM, ADR-0005) and SQL migrations. Schema-as-code and offline migration generation; the live connection and repository implementations are gated on DATABASE_URL.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aflo/ai": "workspace:*",
    "@aflo/notifications": "workspace:*",
    "@aflo/partner-marketplace": "workspace:*",
    "@aflo/rules": "workspace:*",
    "@aflo/security": "workspace:*",
    "@aflo/shared": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
